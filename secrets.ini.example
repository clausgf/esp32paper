; esp32paper — secrets as build flags (alternative to include/settings.h).
;
; Copy this file to `secrets.ini` (git-ignored) and fill in your values, then
; enable it in platformio.ini by uncommenting BOTH:
;   [platformio] extra_configs = secrets.ini
;   [env]        build_flags   = ${secrets.build_flags}  (add to the list)
;
; Useful for CI or when you would rather not keep an include/settings.h. Note:
; the values still end up compiled into the firmware .bin.
;
; Quoting: a C string literal must survive the ini + compiler, hence the
; '"..."' wrapping (single quotes around the double-quoted string).

[secrets]
build_flags =
    -DWIFI_SSID='"my-wifi"'
    -DWIFI_PASSWORD='"my-password"'
    -DIOT_API_URL='"http://192.168.178.20:8000/api"'
    -DIOT_PROJECT='"my-project"'
    -DIOT_PROVISIONING_TOKEN='"P-102-FX61O...=="'
